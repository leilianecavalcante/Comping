<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comping Lista de Compras</title>
  <link rel="stylesheet" href="style.css">
  <img src="COMPRARE.png" alt="Logotipo da Empresa" class="logo">
</head>
<body>
  <h1>LISTA DE COMPRAS</h1>

  <div id="formulario">
    <h2>Adicionar ao Carrinho</h2>
    <form id="cadastroForm">
      <label for="nome">Item:</label>
      <input type="text" id="nome" required>

      <label for="categoria">Categoria:</label>
      <select id="categoria" required>
        <option value="" disabled selected>Selecionar</option>
        <option value="frutas">Frutas e Verduras</option>
        <option value="limpeza">Produtos de Limpeza</option>
        <option value="carnes">Carnes e Peixes</option>
        <option value="laticinios">Laticínios</option>
        <option value="padaria">Padaria</option>
        <option value="bebidas">Bebidas</option>
        <option value="mercearia">Mercearia</option>
      </select>
      
      <button type="submit">Adicionar</button>
    </form>
  </div>

  <div id="frutaseverduras" class="lista">
    <h2>Frutas e Verduras</h2>
    <ul id="listafrutas"></ul>
  </div>
  
  <div id="limpeza" class="lista">
    <h2>Produtos de Limpeza</h2> 
    <ul id="listalimpeza"></ul>  
  </div>
  
  <div id="carnes" class="lista">
    <h2>Carnes e Peixes</h2>
    <ul id="listadecarnes"></ul>
  </div>

  <div id="laticinios" class="lista">
    <h2>Laticínios</h2>
    <ul id="listadelaticinios"></ul>
  </div>

  <div id="padaria" class="lista">
    <h2>Padaria</h2>
    <ul id="listadepadaria"></ul>
  </div>

  <div id="bebidas" class="lista">
    <h2>Bebidas</h2>
    <ul id="listadebebidas"></ul>
  </div>

  <div id="mercearia" class="lista">
    <h2>Mercearia</h2>
    <ul id="listademercearia"></ul>
  </div>

  <script src="script.js"></script>
</body>
<footer>

</footer>
</html>
